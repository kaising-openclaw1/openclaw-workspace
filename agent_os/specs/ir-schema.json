{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agent-os.dev/specs/ir-schema.json",
  "title": "Agent OS IR Schema",
  "description": "Task Graph Intermediate Representation schema v1.0",
  "version": "1.0.0",
  "type": "object",
  "required": ["graph_id", "version", "created_at", "session_id", "user_intent", "max_concurrency", "timeout_seconds", "tasks", "entry_points", "output_tasks"],
  "properties": {
    "graph_id": { "type": "string", "pattern": "^g-[a-f0-9-]+$" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "session_id": { "type": "string" },
    "user_intent": { "type": "string", "minLength": 1 },
    "max_concurrency": { "type": "integer", "minimum": 1, "maximum": 100 },
    "timeout_seconds": { "type": "integer", "minimum": 1 },
    "entry_points": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "output_tasks": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "tasks": {
      "type": "object",
      "additionalProperties": { "$ref": "#/definitions/TaskIR" }
    },
    "global_constraints": {
      "type": "array",
      "items": { "$ref": "#/definitions/GlobalConstraint" }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "planner_model": { "type": "string" },
        "planner_prompt_version": { "type": "string" },
        "total_estimated_cost": { "type": "number", "minimum": 0 },
        "tags": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "definitions": {
    "TaskIR": {
      "type": "object",
      "required": ["id", "name", "description", "dependencies", "dependency_mode", "executor", "input_schema", "output_schema", "validation"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "dependencies": { "type": "array", "items": { "type": "string" } },
        "dependency_mode": { "type": "string", "enum": ["all", "any"] },
        "executor": { "type": "string", "enum": ["llm", "tool", "code", "human", "composite"] },
        "model": { "type": "string" },
        "tool_id": { "type": "string" },
        "timeout_seconds": { "type": "integer", "minimum": 1 },
        "max_retries": { "type": "integer", "minimum": 0, "default": 2 },
        "retry_delay_seconds": { "type": "integer", "minimum": 0, "default": 5 },
        "input_schema": { "$ref": "#/definitions/IRSchema" },
        "output_schema": { "$ref": "#/definitions/IRSchema" },
        "validation": { "$ref": "#/definitions/ValidationConfig" },
        "cost": {
          "type": "object",
          "properties": {
            "max_tokens": { "type": "integer", "minimum": 1 },
            "max_cost_usd": { "type": "number", "minimum": 0 }
          }
        },
        "context": {
          "type": "object",
          "properties": {
            "include_artifacts": { "type": "array", "items": { "type": "string" } },
            "max_context_tokens": { "type": "integer", "minimum": 1 }
          }
        },
        "on_failure": { "$ref": "#/definitions/FailureHandler" },
        "metadata": { "type": "object" }
      }
    },
    "IRSchema": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "enum": ["object", "array", "string", "number", "boolean", "null"] },
        "properties": {
          "type": "object",
          "additionalProperties": { "$ref": "#/definitions/IRSchema" }
        },
        "items": { "$ref": "#/definitions/IRSchema" },
        "required": { "type": "array", "items": { "type": "string" } },
        "enum": { "type": "array" },
        "description": { "type": "string" },
        "default": {},
        "example": {},
        "minLength": { "type": "integer", "minimum": 0 },
        "maxLength": { "type": "integer", "minimum": 1 },
        "minimum": { "type": "number" },
        "maximum": { "type": "number" },
        "pattern": { "type": "string" }
      }
    },
    "ValidationConfig": {
      "type": "object",
      "required": ["level", "schema_validation", "acceptance"],
      "properties": {
        "level": { "type": "string", "enum": ["none", "schema_only", "full"] },
        "schema_validation": {
          "type": "object",
          "required": ["strict"],
          "properties": {
            "strict": { "type": "boolean" },
            "coerce_types": { "type": "boolean" }
          }
        },
        "semantic": {
          "type": "object",
          "properties": {
            "contradiction_check": { "type": "boolean" },
            "contradiction_domains": { "type": "array", "items": { "type": "string" } },
            "claim_overlap_check": { "type": "boolean" },
            "overlap_threshold": { "type": "number", "minimum": 0, "maximum": 1 },
            "custom_validators": { "type": "array", "items": { "type": "string" } }
          }
        },
        "acceptance": {
          "type": "object",
          "required": ["min_confidence"],
          "properties": {
            "min_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
            "require_human_review": { "type": "boolean" }
          }
        }
      }
    },
    "FailureHandler": {
      "type": "object",
      "required": ["action"],
      "properties": {
        "action": { "type": "string", "enum": ["retry", "skip", "fail_graph", "fallback", "notify_human"] },
        "fallback_task": { "$ref": "#/definitions/TaskIR" },
        "degradation": {
          "type": "object",
          "properties": {
            "reduce_quality": { "type": "boolean" },
            "use_cheaper_model": { "type": "string" },
            "simplify_schema": { "type": "boolean" }
          }
        },
        "notify_on": { "type": "array", "items": { "type": "string", "enum": ["retry", "skip", "fail"] } }
      }
    },
    "GlobalConstraint": {
      "type": "object",
      "required": ["kind", "value"],
      "properties": {
        "kind": { "type": "string", "enum": ["resource_limit", "time_limit", "cost_limit", "security_policy"] },
        "value": {},
        "description": { "type": "string" }
      }
    }
  }
}
